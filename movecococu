local KEY_TARGET = 0x54 -- T
local KEY_ACTIVE = 0x48 -- H
local KEY_SPRINT = 0xA0 -- Left Shift

local W, A, S, D, SPACE = 0x57, 0x41, 0x53, 0x44, 0x20

local DEADZONE = 0.38       -- 8-way boundary (cos 67.5)
local STOP_SPEED = 2.0      -- velocity-fallback floor only
local MOVE_MIN = 0.05
local JUMP_HOLD_MS = 120
local JUMP_VELOCITY = 8
local MAX_DELAY_MS = 10000
local RING_RADIUS = 2.5
local RING_SEGMENTS = 28
local MARKER = color(1, 0.15, 0.15, 1)
local WHITE = color(1, 1, 1, 1)

