    [humanoid_state.RAGDOLL]           = true,
    [humanoid_state.GETTING_UP]        = true,
    [humanoid_state.SEATED]            = true,
    [humanoid_state.PLATFORM_STANDING] = true,
    [humanoid_state.DEAD]              = true,
    [humanoid_state.PHYSICS]           = true,
}

